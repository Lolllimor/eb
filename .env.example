# Server
PORT=3001

# Admin JWT (required for protected routes). Generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# Session length in seconds (default: 7 days)
# JWT_EXPIRES_SEC=604800

# Public URL of your Next.js app — used to build invite links (returned in API response)
# INVITE_BASE_URL=http://localhost:3000

# Optional: log full invite URL to stdout (discouraged in production)
# LOG_INVITE_LINKS=1

# Optional: log password-reset OTP to stdout (dev only — never enable in production)
# LOG_RESET_OTP=1

# First super admin — only applied by `npm run seed` when no admin with this email exists yet
# Both must be set; there are no default credentials.
# INITIAL_SUPER_ADMIN_EMAIL=admin@example.com
# INITIAL_SUPER_ADMIN_PASSWORD=

# Database (optional – defaults to ./data/emprinte.db)
# DB_PATH=./data/emprinte.db

# CORS (optional – comma-separated origins, no trailing slash; must match browser Origin exactly)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://emprinte.com,https://emprinte-git-version2-lolllimors-projects.vercel.app/
